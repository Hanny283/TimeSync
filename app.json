{
  "expo": {
    "name": "TimeSync",
    "slug": "TimeSync",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/logo.png",
    "scheme": "timesync",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.hanny283.timesync",
      "appleTeamId": "JTAWXDG2KQ",
      "infoPlist": {
        "NSContactsUsageDescription": "TimeSync requests access to your contacts to help you share locks with trusted contacts."
      }
    },
    "android": {
      "package": "com.hanny283.timesync",
      "adaptiveIcon": {
        "backgroundColor": "#000000",
        "foregroundImage": "./assets/images/logo.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/logo.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/logo.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/logo.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      [
        "expo-build-properties",
        {
          "ios": {
            "deploymentTarget": "15.1"
          }
        }
      ],
      [
        "react-native-device-activity",
        {
          "appleTeamId": "JTAWXDG2KQ",
          "appGroup": "group.com.hanny283.timesync"
        }
      ],
      "./plugins/with-screen-time-entitlements"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "build": {
          "experimental": {
            "ios": {
              "appExtensions": [
                {
                  "bundleIdentifier": "com.hanny283.timesync.ShieldConfiguration",
                  "targetName": "ShieldConfiguration",
                  "entitlements": {
                    "com.apple.developer.family-controls": true,
                    "com.apple.security.application-groups": [
                      "group.com.hanny283.timesync"
                    ]
                  }
                },
                {
                  "bundleIdentifier": "com.hanny283.timesync.ShieldAction",
                  "targetName": "ShieldAction",
                  "entitlements": {
                    "com.apple.developer.family-controls": true,
                    "com.apple.security.application-groups": [
                      "group.com.hanny283.timesync"
                    ]
                  }
                },
                {
                  "bundleIdentifier": "com.hanny283.timesync.ActivityMonitorExtension",
                  "targetName": "ActivityMonitorExtension",
                  "entitlements": {
                    "com.apple.developer.family-controls": true,
                    "com.apple.security.application-groups": [
                      "group.com.hanny283.timesync"
                    ]
                  }
                }
              ]
            }
          }
        },
        "projectId": "2d3d798f-266b-4b56-ac73-59cb13e7d681"
      }
    },
    "owner": "gabrielcastillo"
  }
}
